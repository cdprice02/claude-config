{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoUpdatesChannel": "latest",
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "eros-codex@ErosMarketplace": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "python ~/.claude/hooks/auto_lint_python.py",
            "timeout": 15,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "python ~/.claude/hooks/secret_scan.py",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      },
      {
        "hooks": [
          {
            "command": "python ~/.claude/hooks/git_add_scan.py",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ]
  },
  "model": "us.anthropic.claude-opus-4-6-v1",
  "permissions": {
    "allow": [
      "Bash(* --help)",
      "Bash(* --help *)",
      "Bash(* --version)",
      "Bash(bandit *)",
      "Bash(black *)",
      "Bash(cargo audit*)",
      "Bash(cargo build*)",
      "Bash(cargo check*)",
      "Bash(cargo clippy*)",
      "Bash(cargo doc*)",
      "Bash(cargo fmt*)",
      "Bash(cargo search *)",
      "Bash(cargo tree*)",
      "Bash(cat *)",
      "Bash(comm *)",
      "Bash(claude agents*)",
      "Bash(claude auth status*)",
      "Bash(claude doctor*)",
      "Bash(claude mcp get *)",
      "Bash(claude mcp list*)",
      "Bash(claude plugin list*)",
      "Bash(claude plugin marketplace list*)",
      "Bash(claude plugin validate *)",
      "Bash(conda env list)",
      "Bash(conda info*)",
      "Bash(conda list*)",
      "Bash(cut *)",
      "Bash(df -h*)",
      "Bash(diff *)",
      "Bash(du -h --max-depth=*)",
      "Bash(du -sh *)",
      "Bash(file *)",
      "Bash(flake8 *)",
      "Bash(free -h*)",
      "Bash(free -m*)",
      "Bash(git add *)",
      "Bash(git blame*)",
      "Bash(git branch -a*)",
      "Bash(git describe*)",
      "Bash(git diff*)",
      "Bash(git fetch*)",
      "Bash(git grep*)",
      "Bash(git log*)",
      "Bash(git ls-files*)",
      "Bash(git remote -v)",
      "Bash(git show*)",
      "Bash(git stash list)",
      "Bash(git status)",
      "Bash(git tag -l*)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(hostname)",
      "Bash(isort --check-only *)",
      "Bash(jq *)",
      "Bash(ls*)",
      "Bash(mypy *)",
      "Bash(pip check)",
      "Bash(pip list*)",
      "Bash(pip show *)",
      "Bash(pdffonts *)",
      "Bash(pdfimages -list *)",
      "Bash(pdfinfo *)",
      "Bash(pdfseparate *)",
      "Bash(pdftotext *)",
      "Bash(pwd)",
      "Bash(python -P -m json.tool *)",
      "Bash(python -P -m py_compile *)",
      "Bash(python -P -m pyright *)",
      "Bash(ruff *)",
      "Bash(rustc --explain *)",
      "Bash(rustfmt --check *)",
      "Bash(sort *)",
      "Bash(stat *)",
      "Bash(tail *)",
      "Bash(tree *)",
      "Bash(uname -a)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(whereis *)",
      "Bash(which *)",
      "Bash(* | head *)",
      "Bash(* | tail *)",
      "Bash(* | wc *)",
      "Bash(* | grep *)",
      "Bash(* | sort *)",
      "Bash(* | uniq *)",
      "Bash(cat *.json | jq *)",
      "Bash(cat *.json | jq * | head *)",
      "Bash(cat *.json | jq * | grep *)",
      "Bash(git log* | *)",
      "Bash(git diff* | *)",
      "Bash(git show* | *)",
      "Bash(git grep* | *)",
      "Bash(git blame* | *)",
      "Bash(ls* | *)",
      "Bash(tree * | *)",
      "Bash(du * | *)",
      "Bash(df * | *)",
      "Bash(cat * | *)",
      "Bash(pip list* | *)",
      "Bash(conda list* | *)",
      "Bash(cargo tree* | *)",
      "Glob",
      "Grep",
      "Read(/tmp/**)",
      "Write(/tmp/**)",
      "Edit(/tmp/**)",
      "Bash(ls /tmp*)",
      "Bash(mkdir -p /tmp/*)",
      "Bash(touch /tmp/*)",
      "Bash(rm /tmp/*)",
      "Read(~/.bashrc)",
      "Read(~/.zshrc)",
      "Read(~/AppData/Roaming/nushell/config.nu)",
      "Read(~/AppData/Roaming/nushell/env.nu)",
      "Read(~/.claude/**)",
      "WebFetch(domain:api.anthropic.com)",
      "WebFetch(domain:api.openai.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:doi.org)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:man7.org)",
      "WebFetch(domain:python-docs.readthedocs.io)",
      "WebFetch(domain:python.org)",
      "WebFetch(domain:stackexchange.com)",
      "WebFetch(domain:usgs.gov)",
      "WebFetch(domain:wikipedia.org)",
      "mcp__context7__*",
      "mcp__pyright-lsp__*",
      "mcp__rust-analyzer-lsp__*",
      "mcp__eros-codex__*",
      "mcp__mcp-obsidian__obsidian_list_files_in_vault",
      "mcp__mcp-obsidian__obsidian_list_files_in_dir",
      "mcp__mcp-obsidian__obsidian_get_file_contents",
      "mcp__mcp-obsidian__obsidian_batch_get_file_contents",
      "mcp__mcp-obsidian__obsidian_simple_search",
      "mcp__mcp-obsidian__obsidian_complex_search",
      "mcp__mcp-obsidian__obsidian_get_periodic_note",
      "mcp__mcp-obsidian__obsidian_get_recent_periodic_notes",
      "mcp__mcp-obsidian__obsidian_get_recent_changes",
      "mcp__mcp-obsidian__obsidian_append_content",
      "mcp__mcp-obsidian__obsidian_patch_content",
      "mcp__mcp-obsidian__obsidian_delete_file"
    ],
    "ask": [
      "Read(~/.claude/settings.local.json)",
      "Read(~/.claude/backups/**)",
      "Read(~/.claude/settings.json)"
    ],
    "deny": [
      "Bash(dd if=/dev/random of=/dev/*)",
      "Bash(dd if=/dev/zero of=/dev/*)",
      "Bash(fdisk*)",
      "Bash(halt*)",
      "Bash(init 0*)",
      "Bash(init 6*)",
      "Bash(mkfs*)",
      "Bash(parted*)",
      "Bash(pkexec *)",
      "Bash(poweroff*)",
      "Bash(reboot*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(shutdown*)",
      "Bash(sudo -i*)",
      "Bash(sudo -l*)",
      "Bash(sudo -V*)",
      "Bash(sudo > /etc/*)",
      "Bash(sudo chmod 777 /*)",
      "Bash(sudo chown * /*)",
      "Bash(sudo reboot*)",
      "Bash(sudo rm /bin/*)",
      "Bash(sudo rm /etc/*)",
      "Bash(sudo rm /usr/*)",
      "Bash(sudo rm -rf /)",
      "Bash(sudo rm -rf /*)",
      "Bash(sudo rm -rf /etc/*)",
      "Bash(sudo shutdown*)",
      "Bash(sudo su*)",
      "Bash(sudo su -*)",
      "Bash(* | sh)",
      "Bash(* | bash)",
      "Bash(* | python -c *)",
      "Bash(* | eval)",
      "Bash(* | source)",
      "Bash(* | exec)",
      "Bash(awk * | *)",
      "Bash(sed -e * | *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./build)",
      "Read(./config/credentials.json)",
      "Read(.envrc)",
      "Read(./secrets/**)",
      "Read(~/.aws/**)"
    ]
  },
  "statusLine": {
    "command": "bunx ccstatusline@latest",
    "type": "command"
  }
}

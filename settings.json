{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "alwaysThinkingEnabled": true,
  "attribution": {
    "commit": "Co-Authored-By: Claude <noreply@anthropic.com>",
    "pr": "Co-Authored-By: Claude <noreply@anthropic.com>"
  },
  "autoUpdatesChannel": "latest",
  "cleanupPeriodDays": 20,
  "enableAllProjectMcpServers": true,
  "enabledPlugins": {
    "commit-commands@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/scripts/format-on-edit.sh",
            "statusMessage": "Formatting...",
            "type": "command"
          },
          {
            "command": "bash ~/.claude/scripts/clippy-on-edit.sh",
            "statusMessage": "Checking...",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/scripts/session-start.sh",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "bash ~/.claude/scripts/bootstrap.sh",
            "type": "command"
          }
        ]
      }
    ]
  },
  "includeCoAuthoredBy": true,
  "mcpServers": {
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "type": "stdio",
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      }
    },
    "localdata": {
      "command": "localdata-mcp",
      "type": "stdio"
    }
  },
  "model": "us.anthropic.claude-sonnet-4-6",

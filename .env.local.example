# ~/.claude/.env.local — Machine-local secrets for Claude Code and MCP servers.
#
# SETUP (required on every machine):
#   1. Copy this file: cp ~/.claude/.env.local.example ~/.claude/.env.local
#   2. Fill in your values below
#   3. Ensure ~/.bashrc sources it (copy this block if missing):
#
#        # Claude Code local secrets (MCP API keys, etc.)
#        if [[ -f "$HOME/.claude/.env.local" ]]; then
#            source "$HOME/.claude/.env.local"
#        fi
#
# WHY THIS FILE EXISTS:
#   ${VAR} in settings.json mcpServers expands from the SHELL environment.
#   MCP servers are child processes that read the shell env at launch time.
#   Secrets must be exported here and sourced in ~/.bashrc before starting Claude Code.
#
# DO NOT commit .env.local — it is gitignored. This example file is safe to commit.

# Profile selection (determines statusline behavior)
# Values: "personal" or "work"
export CLAUDE_PROFILE="personal"

# Obsidian Local REST API key (Obsidian → Settings → Local REST API)
export OBSIDIAN_API_KEY=""

# Brave Search API key — free tier, 2k queries/month (https://api.search.brave.com)
export BRAVE_API_KEY=""

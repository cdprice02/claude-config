# Deny everything by default — only explicitly listed files are tracked
*

# Core config files
!.gitattributes
!.gitignore
!.env.local.example
!CLAUDE.md
!PROJECT_TEMPLATE.md
!README.md
!settings.json

# Profiles — only example/template files
!profiles/
profiles/*
!profiles/personal/
profiles/personal/*
!profiles/personal/*.json.example
!profiles/work/
profiles/work/*
!profiles/work/*.json.example

# Scripts
!scripts/
scripts/*
!scripts/*.sh

# User-level skills
!skills/
skills/*
!skills/*/
skills/*/*
!skills/*/SKILL.md

# User-level subagents
!agents/
agents/*
!agents/*.md

# Local plugins
!plugins/
plugins/*
!plugins/reflection/
!plugins/reflection/**
